# Copy this to .env.local and set the client ID for this build.
# Available: demo-cleaning, demo-realestate, demo-lawfirm, demo-tax, demo-decoration
# Add real clients to config/clients/ and register them in config/index.ts

NEXT_PUBLIC_CLIENT_ID=demo-cleaning

# Kenatrix Core contact endpoint — form submissions POST JSON here.
# Saves to DB and sends Telegram notification instantly.
# Use /sendMessage for Telegram-only, /create for DB-only.
NEXT_PUBLIC_FORM_ENDPOINT=http://localhost:8080/api/v1/public/contact/sendMessage

#NEXT_PUBLIC_FORM_ENDPOINT=https://api.zikwala.com/api/v1/public/contact/sendMessage

# Website order requests from /get-started — POSTs to WebsiteRequestCreateDto
NEXT_PUBLIC_WEBSITE_ORDER_ENDPOINT=https://api.zikwala.com/api/v1/public/website

# Public site URL (used for SEO metadata)
NEXT_PUBLIC_SITE_URL=https://demo.zikwala.com
